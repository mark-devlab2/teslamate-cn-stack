COMPOSE_PROJECT_NAME=teslamate-cn
TM_DOMAIN=car.himark.me
TM_BASE_URL=https://car.himark.me
GRAFANA_URL=https://car.himark.me/grafana
TZ=Asia/Shanghai

TLS_MODE=acme
EDGE_TLS_MODE=acme
ACME_EMAIL=ops@himark.me
ACME_CA_SERVER=letsencrypt
ACME_STAGING=0
PUBLIC_EDGE_NETWORK=himark-public-edge

POSTGRES_DB=teslamate
POSTGRES_USER=teslamate
POSTGRES_PASSWORD=change_me_postgres_password

ENCRYPTION_KEY=change_me_minimum_32_chars
SECRET_KEY_BASE=change_me_secret_key_base
SIGNING_SALT=change_me_signing_salt

TESLA_AUTH_HOST=https://auth.tesla.com
TESLA_API_HOST=https://owner-api.vn.cloud.tesla.cn
TESLA_WSS_HOST=wss://streaming.vn.cloud.tesla.cn

CHECK_ORIGIN=true
TM_MAP_TILE_URL=/tiles/{z}/{x}/{y}.png
TM_GEOCODER_BASE_URL=http://cn-geocoder:8080
CN_GEOCODER_PROVIDER=amap
AMAP_WEB_SERVICE_KEY=
NOMINATIM_FALLBACK_BASE_URL=https://nominatim.openstreetmap.org

TILE_URL_TEMPLATE=https://tile.openstreetmap.org/{z}/{x}/{y}.png
TILE_FALLBACK_URL_TEMPLATE=
TILE_TIMEOUT_SECONDS=10
TILE_CACHE_TTL_SECONDS=2592000
TILE_CACHE_CONTROL=public,max-age=2592000,stale-while-revalidate=86400

MOSQUITTO_USERNAME=teslamate
MOSQUITTO_PASSWORD=change_me_mqtt_password
MQTT_NAMESPACE=

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

BASIC_AUTH_USERNAME=caradmin
BASIC_AUTH_PASSWORD=change_me_basic_auth_password
API_TOKEN=change_me_api_token_min_32_chars
TESLAMATEAPI_ENABLE_COMMANDS=false
TESLAMATEAPI_API_TOKEN_DISABLE=false

NGINX_CLIENT_MAX_BODY_SIZE=2m
NGINX_RATE_LIMIT=30r/m
NGINX_RATE_LIMIT_BURST=20

TM_INIT_LANGUAGE=zh
TM_INIT_UNIT_OF_LENGTH=km
TM_INIT_UNIT_OF_TEMPERATURE=C
TM_INIT_UNIT_OF_PRESSURE=bar
TM_INIT_PREFERRED_RANGE=rated
